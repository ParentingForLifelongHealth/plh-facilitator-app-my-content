{
  "flow_type": "template",
  "flow_name": "new_parent_group",
  "status": "released",
  "rows": [
    {
      "name": "is_new",
      "value": false,
      "exclude_from_translation": true
    },
    {
      "name": "title_label",
      "value": "Edit Parent Group"
    },
    {
      "name": "title_label",
      "value": "New Parent Group",
      "condition": "@local.is_new"
    },
    {
      "exclude_from_translation": true
    },
    {
      "type": "text",
      "value": "group number: @fields.current_group_no",
      "condition": false,
      "exclude_from_translation": true
    },
    {
      "type": "begin_template",
      "name": "header",
      "value": "section_header",
      "action_list": "uncompleted | emit: uncompleted; ",
      "exclude_from_translation": true
    },
    {
      "name": "title",
      "value": "@local.title_label",
      "exclude_from_translation": true
    },
    {
      "name": "confirm_exit",
      "value": true
    },
    {
      "type": "end_template",
      "exclude_from_translation": true
    },
    {
      "exclude_from_translation": true
    },
    {
      "type": "text",
      "name": "text_group_name",
      "value": "Group Name",
      "parameter_list": "style: emphasised",
      "style_list": "word-break: break-word;"
    },
    {
      "type": "text",
      "value": "before: @fields.current_group_no",
      "condition": false,
      "exclude_from_translation": true
    },
    {
      "type": "data_items",
      "name": "get_id",
      "value": "parent_groups",
      "action_list": "data_changed | set_field: current_group_id: @items[0]?.id;\ndata_changed | set_local: is_new: true;",
      "parameter_list": "filter: @item.name == @field.current_group_no;",
      "condition": "@fields.current_group_id == \"new\"",
      "exclude_from_translation": true
    },
    {
      "type": "text_box",
      "name": "text_box",
      "value": "@fields.current_group_name",
      "parameter_list": "placeholder: @local.text_group_name",
      "exclude_from_translation": true
    },
    {
      "name": "name_valid",
      "value": "@calc(!!@local.text_box)",
      "exclude_from_translation": true
    },
    {
      "exclude_from_translation": true
    },
    {
      "exclude_from_translation": true
    },
    {
      "type": "text",
      "name": "name_valid_test",
      "value": "local.name_valid = @local.name_valid",
      "condition": false,
      "exclude_from_translation": true
    },
    {
      "type": "text",
      "name": "delivering_valid_test",
      "value": "delivering_valid = @local.delivering_valid",
      "condition": false,
      "exclude_from_translation": true
    },
    {
      "type": "data_items",
      "name": "get_delivering",
      "value": "parent_groups",
      "action_list": "data_changed | set_local: delivering: @items[0]?.test_group;",
      "parameter_list": "filter: @item.name == @field.current_group_no && !@item.archived;",
      "exclude_from_translation": true
    },
    {
      "type": "text",
      "name": "delivering_text",
      "value": "@global.delivering_text"
    },
    {
      "name": "answer_list_delivering",
      "value": "name: false | text: @global.delivering_yes;\nname: Test | text: @global.delivering_no;",
      "exclude_from_translation": true
    },
    {
      "type": "radio_list",
      "name": "delivering",
      "parameter_list": "answer_list: @local.answer_list_delivering;\n",
      "exclude_from_translation": true
    },
    {
      "name": "delivering_valid",
      "value": "@calc(!!@local.delivering || @local.delivering == false)"
    },
    {
      "name": "valid",
      "value": "@calc(!!@local.name_valid && !!@local.delivering_valid)"
    },
    {
      "type": "begin_display_group",
      "parameter_list": "sticky: bottom;",
      "style_list": "padding: 12px 24px;",
      "condition": "@fields.current_group_no <> \"new\"",
      "exclude_from_translation": true
    },
    {
      "type": "button",
      "name": "save",
      "value": "Next",
      "action_list": "click | set_field: current_group_name: @local.text_box;\nclick | set_field: title_label: @local.title_label;\nclick | set_data |\n_list_id: parent_groups,\n_id: @fields.current_group_id,\ntext: @local.text_box,\narchived: true,\ntest_group: @local.delivering,\ncolour_test: ,\ntimestamp_created: @calc(timestamp());\nclick | emit: server_sync;\nclick | go_to: new_parent_group_page_2;",
      "parameter_list": "variant: card; \ndisabled: !@local.valid",
      "condition": "!!@fields.current_access_code"
    },
    {
      "type": "button",
      "name": "access_code_and_save",
      "value": "Next",
      "action_list": "click | set_field: current_group_name: @local.text_box;\nclick | set_field: title_label: @local.title_label;\nclick | set_data |\n_list_id: parent_groups,\n_id: @fields.current_group_id,\ntext: @local.text_box,\narchived: true,\ntest_group: @local.delivering,\ncolour_test: ,\ntimestamp_created: @calc(timestamp());\nclick | plh_parent_group: generate_access_code | \nparent_group_id: @fields.current_group_id,\nparent_groups_data_list: parent_groups,\nparents_data_list: parents;\nclick | emit: server_sync;\nclick | go_to: new_parent_group_page_2;\n\n",
      "parameter_list": "variant: card; \ndisabled: !@local.valid",
      "condition": "!@fields.current_access_code"
    },
    {
      "type": "end_display_group",
      "exclude_from_translation": true
    }
  ]
}