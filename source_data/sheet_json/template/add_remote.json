{
  "flow_type": "template",
  "flow_name": "add_remote",
  "status": "released",
  "rows": [
    {
      "name": "group_id",
      "value": "@field.current_group_no",
      "comments": "Couldn't use fields in add data"
    },
    {
      "name": "module_id",
      "value": "@field:current_module_no"
    },
    {
      "name": "first_name",
      "value": " "
    },
    {
      "name": "last_name",
      "value": " "
    },
    {
      "name": "now",
      "value": "@calc(now())"
    },
    {
      "type": "text",
      "name": "test1",
      "value": "at least one parent = @local.at_least_one_parent",
      "condition": false
    },
    {
      "type": "text",
      "name": "test2",
      "value": "number of attendance = @local.number_of_attendance ",
      "condition": false
    },
    {
      "type": "text",
      "name": "question_4",
      "value": "Which of the parents attended your online support group session?"
    },
    {
      "name": "parent_count"
    },
    {
      "type": "data_items",
      "name": "find_number_of_parents",
      "value": "parents",
      "action_list": "data_changed | set_local : parent_count : @items.length",
      "parameter_list": "filter: @item.group_id == @field.current_group_id && !@item.archived"
    },
    {
      "type": "text",
      "name": "empty_state_message",
      "value": "@global.empty_state_message",
      "condition": "@local.parent_count == 0"
    },
    {
      "type": "begin_data_items",
      "value": "parents",
      "parameter_list": "filter: @item.group_id == @field.current_group_id && !@item.archived"
    },
    {
      "type": "begin_display_group"
    },
    {
      "name": "first_name",
      "value": "@item.rp_name",
      "exclude_from_translation": true,
      "comments": "This makes sure undefined isnt listed"
    },
    {
      "name": "last_name",
      "value": " ",
      "exclude_from_translation": true
    },
    {
      "name": "first_name",
      "value": "@item.first_name",
      "condition": "@item.first_name",
      "exclude_from_translation": true
    },
    {
      "name": "last_name",
      "value": "@item.last_name",
      "condition": "@item.last_name",
      "exclude_from_translation": true
    },
    {
      "type": "text",
      "value": "@local.first_name @local.last_name",
      "style_list": "flex: 1; word-break: break-word;"
    },
    {
      "type": "simple_checkbox",
      "name": "check_box",
      "value": "@item.@fields.current_module_no",
      "action_list": "changed | set_item| @fields.current_module_no: this.value;",
      "parameter_list": "show_icons: false; variant: ios;",
      "condition": "this.value",
      "comments": "Need to reset this to false"
    },
    {
      "type": "text",
      "name": "test4",
      "value": "checkbox = @local.check_box",
      "condition": false
    },
    {
      "type": "end_display_group",
      "condition": false
    },
    {
      "type": "begin_template",
      "value": "count_attendance",
      "condition": false
    },
    {
      "name": "check",
      "value": "@local.check_box",
      "condition": false
    },
    {
      "type": "end_template",
      "condition": false
    },
    {
      "condition": false
    },
    {
      "type": "text",
      "value": "last = @item._last",
      "condition": false
    },
    {
      "type": "begin_template",
      "value": "check_attendance",
      "condition": false,
      "comments": "@item._last"
    },
    {
      "type": "end_template",
      "condition": false
    },
    {
      "condition": false
    },
    {
      "type": "end_data_items"
    },
    {
      "type": "text",
      "value": "field count attendance = @field.count_attendance",
      "condition": false
    },
    {
      "type": "text",
      "name": "no_parent_added_text",
      "value": "No parents added yet. You need to add parents to your group before you can submit this report.",
      "condition": false,
      "comments": "@field.count_attendance == 0"
    },
    {
      "type": "text",
      "name": "question_1",
      "value": "How many minutes did you spend facilitating your parent online support group over the last week?"
    },
    {
      "type": "text_box",
      "name": "answer_1",
      "parameter_list": "number_input: true; \nplaceholder: @global.minutes; \nmax_length: 3"
    },
    {
      "type": "text",
      "name": "question_2",
      "value": "I was able to send...",
      "condition": false
    },
    {
      "name": "all",
      "value": "All of the messages",
      "condition": false
    },
    {
      "name": "some",
      "value": "Some of the messages",
      "condition": false
    },
    {
      "name": "none",
      "value": "None of the messages",
      "condition": false
    },
    {
      "name": "answer_list_2",
      "value": "name: all | text: @local.all; name: some | text: @local.some; name: none | text: @local.none",
      "condition": false
    },
    {
      "type": "radio_button_grid",
      "name": "answer_2",
      "parameter_list": "item_width: 100%; answer_list: @local.answer_list_2",
      "condition": false
    },
    {
      "type": "text",
      "name": "question_3",
      "value": "How do you feel the session went?",
      "condition": false
    },
    {
      "name": "very_well",
      "value": "Very well"
    },
    {
      "name": "well",
      "value": "Well"
    },
    {
      "name": "ok",
      "value": "Acceptable / Okay"
    },
    {
      "name": "poorly",
      "value": "Poorly"
    },
    {
      "name": "very_poorly",
      "value": "Very Poorly"
    },
    {
      "name": "answer_list_3",
      "value": "name: very_well | text: @local.very_well; name: well | text: @local.well; name: ok | text: @local.ok; name: poorly| text: @local.poorly; name: very_poorly| text: @local.very_poorly;"
    },
    {
      "type": "radio_button_grid",
      "name": "answer_3",
      "parameter_list": "item_width: 100%; answer_list: @local.answer_list_3",
      "condition": false
    },
    {
      "type": "text",
      "name": "checked_count",
      "value": 0,
      "condition": false
    },
    {
      "type": "text",
      "name": "check_map ",
      "condition": false
    },
    {
      "type": "data_items",
      "value": "parents",
      "action_list": "data_changed | set_local : checked_count : @items.length;",
      "parameter_list": "filter: @item.group_id == @field.current_group_id && !@item.archived && !!(@item.@local.module_id)",
      "condition": false
    },
    {
      "type": "text",
      "name": "checked_count_text",
      "value": "checked_count = @local.checked_count",
      "condition": false
    },
    {
      "condition": false
    },
    {
      "type": "data_items",
      "value": "parents",
      "action_list": "data_changed | set_local : check_map : @items.map(item => item.@local.module_id);",
      "parameter_list": "filter: @item.group_id == @field.current_group_id && !@item.archived;",
      "condition": false
    },
    {
      "type": "text",
      "name": "checking_count",
      "value": "checking count = @calc((@local.check_map.filter(x => TRUE))",
      "condition": false
    },
    {
      "name": "today",
      "value": "@calc(now())"
    },
    {
      "type": "text",
      "value": "Date of session"
    },
    {
      "type": "date_time_picker",
      "name": "session_date",
      "parameter_list": "type: date;\nmax: @local.today;"
    },
    {
      "name": "session_date_valid",
      "value": "!!@local.session_date"
    },
    {
      "type": "begin_display_group",
      "parameter_list": "sticky: bottom",
      "style_list": "padding: 12px 24px"
    },
    {
      "type": "button",
      "name": "save",
      "value": "Save",
      "action_list": "click | add_data | \n_list_id: report_answers,\ngroup_id: @field.current_group_no ,\nmodule_id: @field.current_module_no ,\nsession_date: @local.session_date,\narchived: false,\ntype: \"virtual\",\nquestion_1: @local.answer_1,\nquestion_2: @local.answer_2,\nquestion_3: @local.answer_3,\ncreation_date: @local.now;\nclick | emit: completed;\nclick | emit: server_sync;"
    },
    {
      "type": "end_display_group"
    }
  ]
}