{
  "flow_type": "template",
  "flow_name": "feedback_form",
  "status": "released",
  "rows": [
    {
      "type": "title",
      "value": "Feedback Form"
    },
    {
      "type": "text",
      "value": "Your Feedback"
    },
    {
      "type": "text_area",
      "name": "text_feedback",
      "parameter_list": "placeholder: Tell us what's on your mind..."
    },
    {
      "name": "text_feedback_valid",
      "value": "@calc(!!@local.text_feedback)",
      "comment": true
    },
    {
      "name": "which_app_options",
      "value": "name: parent | text: @global.parent_app_name;  \nname: facilitator | text: @global.app_name;"
    },
    {
      "type": "text",
      "value": "Which app?"
    },
    {
      "type": "radio_list",
      "name": "which_app",
      "parameter_list": "placeholder: Which app?;\nanswer_list: @local.which_app_options;"
    },
    {
      "name": "which_app_valid",
      "value": "@calc(!!@local.which_app)",
      "comment": true
    },
    {
      "type": "text",
      "value": "Where?"
    },
    {
      "type": "combo_box",
      "name": "where",
      "parameter_list": "placeholder: Where?;\nanswer_list: @data.where_options;"
    },
    {
      "name": "specify_location"
    },
    {
      "type": "text_box",
      "name": "specify_location",
      "parameter_list": "placeholder: Please specify the location",
      "condition": "@local.where == \"other\""
    },
    {
      "name": "where_valid",
      "value": "@calc(!!@local.where)",
      "comment": true
    },
    {
      "name": "valid",
      "value": "@local.text_feedback_valid && @local.which_app_valid && @local.where_valid"
    },
    {
      "type": "button",
      "value": "Submit Feedback",
      "action_list": "click | add_data | \n_list_id: feedback_data,\ntext: @local.text_feedback,\nwhich_app: @local.which_app,\nwhere: @local.where,\nspecify_location: @local.specify_location,\ntimestamp: @calc(timestamp());\nclick | emit: completed;\nclick | toast | message: Thanks! This helps us improve your experience on the app;",
      "parameter_list": "disabled: !@local.valid;\nstyle: flexible;",
      "style_list": "margin-bottom: 24px;\npadding: 12px 24px"
    }
  ]
}