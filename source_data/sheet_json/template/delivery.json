{
  "flow_type": "template",
  "flow_name": "delivery",
  "status": "released",
  "rows": [
    {
      "type": "text",
      "name": "delivering_text",
      "value": "@global.delivering_text"
    },
    {
      "name": "answer_list_delivering",
      "value": "name: | text: @global.delivering_yes;\nname: Test | text: @global.delivering_no;",
      "exclude_from_translation": true
    },
    {
      "exclude_from_translation": true
    },
    {
      "type": "radio_list",
      "name": "delivering",
      "parameter_list": "answer_list: @local.answer_list_delivering;\n",
      "exclude_from_translation": true
    },
    {
      "type": "begin_display_group",
      "parameter_list": "sticky: bottom;",
      "style_list": "padding: 12px 24px;"
    },
    {
      "type": "button",
      "value": "Save",
      "action_list": "click | set_field: delivery_done: true;\nclick | set_field: delivery: @local.delivering;\nclick | emit: completed;",
      "parameter_list": "variant: card; "
    },
    {
      "type": "end_display_group"
    }
  ]
}